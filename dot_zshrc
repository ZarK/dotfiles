# ~/.zshrc  ─ lean and readable

HISTSIZE=100000
SAVEHIST=$HISTSIZE
setopt INC_APPEND_HISTORY SHARE_HISTORY HIST_IGNORE_DUPS

if [[ "$PWD" != "$(pwd -P)" ]]; then
  builtin cd -qP . 2>/dev/null
fi

if [[ -L /usr/local/share/zsh/site-functions/_mdatp && ! -e /usr/local/share/zsh/site-functions/_mdatp ]]; then
  fpath=(${fpath:#/usr/local/share/zsh/site-functions})
fi

# Prompt & helpers
eval "$(starship init zsh)"
eval "$(zoxide init zsh)"

# fzf keys (load if it exists, else ignore)
[[ -f "$HOME/.homebrew/opt/fzf/shell/key-bindings.zsh" ]] && \
  source "$HOME/.homebrew/opt/fzf/shell/key-bindings.zsh"

# Aliases
alias ls='eza -lah --group-directories-first'
alias tailscale='/Applications/Tailscale.app/Contents/MacOS/Tailscale'
alias edit='RETURN_DIR=$(pwd) && nano ~/.zshrc && cd "$RETURN_DIR" && source ~/.zshrc'
alias czkawka_cli='~/Applications/czkawka_cli'

# Developer Tools
alias code="open ~/Applications/Visual\ Studio\ Code.app"
alias ollama="~/Applications/Ollama.app/Contents/MacOS/Ollama"
alias orb="~/Applications/OrbStack.app/Contents/MacOS/orb"
alias windsurf="$HOME/.codeium/windsurf/bin/windsurf"

# Browsers
alias vivaldi="open ~/Applications/Vivaldi.app"

# Media
alias vlc="open ~/Applications/VLC.app"

# Productivity
alias obsidian="open ~/Applications/Obsidian.app"
alias raycast="open ~/Applications/Raycast.app"

# Utilities
alias keka="open ~/Applications/Keka.app"
alias localai="$HOME/tools/opencode-local/start-opencode-local.sh"
alias protonmail="open ~/Applications/Proton\ Mail.app"

# Friday AI Assistant with user-specific config
alias friday='friday-wrapper'

if [ -d "$HOME/.ai/bin" ]; then
  export PATH="$HOME/.ai/bin:$PATH"
fi

# Dynamic content added by installers
if [ -s "$HOME/.bun/_bun" ]; then
  # bun completions
  source "$HOME/.bun/_bun"
  
  # bun
  export BUN_INSTALL="$HOME/.bun"
  export PATH="$BUN_INSTALL/bin:$PATH"
fi

if [ -d "$HOME/.codeium/windsurf/bin" ]; then
  # Added by Windsurf
  export PATH="$HOME/.codeium/windsurf/bin:$PATH"
fi

# asdf version manager
. "$HOME/.homebrew/opt/asdf/libexec/asdf.sh"

# Exports
export EDITOR=nano

# Local, untracked overrides (API keys, machine-specific stuff)
if [ -f "$HOME/.zshrc.local" ]; then
  source "$HOME/.zshrc.local"
fi

# dotnet
export DOTNET_ROOT=$HOME/.asdf/installs/dotnet/10.0.101

# Added by Antigravity
export PATH="/Users/tjalve/.antigravity/antigravity/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"
export PATH="$PATH:/Users/tjalve/.dotnet/tools"
export PATH="/opt/homebrew/opt/coreutils/libexec/gnubin:$PATH"

# cubic
export PATH=/Users/tjalve/.cubic/bin:$PATH

# Added by Windsurf - Next
export PATH="/Users/tjalve/.codeium/windsurf/bin:$PATH"

# Added by git-ai installer on Sun Mar  8 11:11:30 CET 2026
export PATH="/Users/tjalve/.git-ai/bin:$PATH"

# opencode
export PATH=/Users/tjalve/.opencode/bin:$PATH
