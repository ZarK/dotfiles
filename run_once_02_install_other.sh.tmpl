#!/usr/bin/env bash
set -euo pipefail

# 1. Install Bun (official method, not via Homebrew)
if ! command -v bun &>/dev/null; then
  echo "Installing Bun (JavaScript runtime) via official script..."
  curl -fsSL https://bun.sh/install | bash
else
  echo "Bun is already installed."
fi

export BUN_INSTALL="${BUN_INSTALL:-$HOME/.bun}"
export PATH="$BUN_INSTALL/bin:$PATH"

# 2. Install OpenClaw CLI (prefer Bun, fall back to npm)
if command -v bun &>/dev/null; then
  if ! command -v openclaw &>/dev/null; then
    echo "Installing OpenClaw CLI via Bun..."
    bun add --global openclaw@latest
  else
    echo "OpenClaw CLI is already installed."
  fi
elif command -v npm &>/dev/null; then
  if ! command -v openclaw &>/dev/null; then
    echo "Installing OpenClaw CLI via npm fallback..."
    npm install -g openclaw@latest
  else
    echo "OpenClaw CLI is already installed."
  fi
else
  echo "Skipping OpenClaw install because neither Bun nor npm is available yet."
fi
