#!/usr/bin/env bash
set -euo pipefail

AI_HOME="${AI_HOME:-$HOME/.ai}"
AI_MODEL_DIR="${AI_MODEL_DIR:-$HOME/models}"
PRIMARY_MANIFEST="${AI_MANIFEST_FILE:-$AI_HOME/manifest.txt}"
LOCAL_MANIFEST="$AI_HOME/manifest.local.txt"

usage() {
  cat <<'EOF'
Usage:
  ai-model download <huggingface-url-or-repo> [target-name]
  ai-model download --manifest
  ai-model list
  ai-model path
  ai-model manifest

Examples:
  ai-model download mlx-community/Hermes-4-70B-MLX-4bit
  ai-model download https://huggingface.co/Brooooooklyn/Qwen3.6-35B-A3B-UD-Q8_K_XL-mlx
  ai-model download --manifest
EOF
}

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    printf 'Missing required command: %s\n' "$1" >&2
    exit 1
  fi
}

trim() {
  python3 - "$1" <<'PY'
import sys
print(sys.argv[1].strip())
PY
}

normalize_repo() {
  python3 - "$1" <<'PY'
from urllib.parse import urlparse
import sys

value = sys.argv[1].strip()
if not value:
    raise SystemExit("Missing Hugging Face repository or URL")

if value.startswith(("http://", "https://")):
    parsed = urlparse(value)
    if parsed.netloc not in {"huggingface.co", "www.huggingface.co"}:
        raise SystemExit(f"Unsupported model URL: {value}")
    parts = [part for part in parsed.path.split("/") if part]
    if parts and parts[0] in {"models", "datasets", "spaces"}:
        if parts[0] != "models":
            raise SystemExit(f"Only Hugging Face model URLs are supported: {value}")
        parts = parts[1:]
    if len(parts) < 2:
        raise SystemExit(f"Could not determine repository from URL: {value}")
    print("/".join(parts[:2]))
else:
    parts = [part for part in value.strip("/").split("/") if part]
    if len(parts) != 2:
        raise SystemExit(
            "Expected owner/repo or a Hugging Face model URL, for example "
            "Brooooooklyn/Qwen3.6-35B-A3B-UD-Q8_K_XL-mlx"
        )
    print("/".join(parts))
PY
}

remember_repo() {
  python3 - "$1" "$PRIMARY_MANIFEST" "$LOCAL_MANIFEST" <<'PY'
from pathlib import Path
import sys

repo, primary_manifest, local_manifest = sys.argv[1:4]

def contains_repo(path: str) -> bool:
    try:
        with open(path, encoding="utf-8") as handle:
            for raw_line in handle:
                if raw_line.split("#", 1)[0].strip() == repo:
                    return True
    except OSError:
        return False
    return False

if contains_repo(primary_manifest) or contains_repo(local_manifest):
    print("present")
    raise SystemExit(0)

path = Path(local_manifest)
path.parent.mkdir(parents=True, exist_ok=True)
existing = path.read_text(encoding="utf-8") if path.exists() else ""
prefix = "" if not existing or existing.endswith("\n") else "\n"
with path.open("a", encoding="utf-8") as handle:
    handle.write(f"{prefix}{repo}\n")

print("added")
PY
}

download_repo() {
  local raw_repo="$1"
  local repo
  local remember_status

  repo="$(normalize_repo "$raw_repo")"
  local target_name="${2:-${repo##*/}}"
  local target_dir="$AI_MODEL_DIR/$target_name"

  require_cmd uv
  mkdir -p "$AI_MODEL_DIR"
  printf 'Downloading %s -> %s\n' "$repo" "$target_dir"
  uv tool run --from huggingface_hub hf download "$repo" --local-dir "$target_dir"

  remember_status="$(remember_repo "$repo")"
  if [ "$remember_status" = "added" ]; then
    printf 'Added %s to %s\n' "$repo" "$LOCAL_MANIFEST"
  fi
}

download_manifest_file() {
  local manifest_file="$1"
  [ -f "$manifest_file" ] || return 0

  while IFS= read -r raw_line || [ -n "$raw_line" ]; do
    local line="${raw_line%%#*}"
    line="$(trim "$line")"
    [ -n "$line" ] || continue
    download_repo "$line"
  done < "$manifest_file"
}

print_manifest() {
  local found=0

  for manifest_file in "$PRIMARY_MANIFEST" "$LOCAL_MANIFEST"; do
    if [ -f "$manifest_file" ]; then
      found=1
      printf '# %s\n' "$manifest_file"
      sed '/^[[:space:]]*#/d;/^[[:space:]]*$/d' "$manifest_file"
    fi
  done

  if [ "$found" -eq 0 ]; then
    printf 'No manifest found. Expected %s\n' "$PRIMARY_MANIFEST" >&2
    exit 1
  fi
}

list_models() {
  mkdir -p "$AI_MODEL_DIR"
  python3 - "$AI_MODEL_DIR" <<'PY'
import os
import sys

root = sys.argv[1]
entries = [name for name in sorted(os.listdir(root)) if os.path.isdir(os.path.join(root, name))]
for entry in entries:
    print(entry)
PY
}

command="${1:-}"
case "$command" in
  download)
    shift
    case "${1:-}" in
      --manifest)
        download_manifest_file "$PRIMARY_MANIFEST"
        download_manifest_file "$LOCAL_MANIFEST"
        ;;
      "")
        usage >&2
        exit 1
        ;;
      *)
        repo="$1"
        target_name="${2:-}"
        download_repo "$repo" "$target_name"
        ;;
    esac
    ;;
  list)
    list_models
    ;;
  path)
    printf '%s\n' "$AI_MODEL_DIR"
    ;;
  manifest)
    print_manifest
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
