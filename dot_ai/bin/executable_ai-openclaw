#!/usr/bin/env bash
set -euo pipefail

AI_HOME="${AI_HOME:-$HOME/.ai}"
AI_OMLX_HOST="${AI_OMLX_HOST:-127.0.0.1}"
AI_OMLX_PORT="${AI_OMLX_PORT:-11435}"
AI_OMLX_TIMEOUT="${AI_OMLX_TIMEOUT:-1}"
AI_OPENCLAW_CONTEXT_WINDOW="${AI_OPENCLAW_CONTEXT_WINDOW:-128000}"
AI_OPENCLAW_MAX_TOKENS="${AI_OPENCLAW_MAX_TOKENS:-8192}"
PRIMARY_MANIFEST="${AI_MANIFEST_FILE:-$AI_HOME/manifest.txt}"
OPENCLAW_CONFIG_FILE="${OPENCLAW_CONFIG_PATH:-$HOME/.openclaw/openclaw.json}"

usage() {
  cat <<'EOF'
Usage:
  ai-openclaw configure [model-id]
  ai-openclaw status
  ai-openclaw doctor
  ai-openclaw dashboard
EOF
}

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    printf 'Missing required command: %s\n' "$1" >&2
    exit 1
  fi
}

detect_model_from_server() {
  python3 - "$AI_OMLX_HOST" "$AI_OMLX_PORT" "$AI_OMLX_TIMEOUT" <<'PY'
import json
import sys
import urllib.request

host = sys.argv[1]
port = sys.argv[2]
timeout = float(sys.argv[3])
url = f"http://{host}:{port}/v1/models"

try:
    with urllib.request.urlopen(url, timeout=timeout) as response:
        payload = json.load(response)
except Exception:
    raise SystemExit(1)

for item in payload.get("data", []):
    model_id = item.get("id")
    if model_id:
        print(model_id)
        break
else:
    raise SystemExit(1)
PY
}

list_models_from_server() {
  python3 - "$AI_OMLX_HOST" "$AI_OMLX_PORT" "$AI_OMLX_TIMEOUT" <<'PY'
import json
import sys
import urllib.request

host = sys.argv[1]
port = sys.argv[2]
timeout = float(sys.argv[3])
url = f"http://{host}:{port}/v1/models"

try:
    with urllib.request.urlopen(url, timeout=timeout) as response:
        payload = json.load(response)
except Exception:
    raise SystemExit(1)

found = False
for item in payload.get("data", []):
    model_id = item.get("id")
    if model_id:
        found = True
        print(model_id)

if not found:
    raise SystemExit(1)
PY
}

server_status() {
  python3 - "$AI_OMLX_HOST" "$AI_OMLX_PORT" "$AI_OMLX_TIMEOUT" <<'PY'
import json
import sys
import urllib.request

host = sys.argv[1]
port = sys.argv[2]
timeout = float(sys.argv[3])
url = f"http://{host}:{port}/v1/models"

try:
    with urllib.request.urlopen(url, timeout=timeout) as response:
        payload = json.load(response)
except Exception:
    print("unreachable")
    raise SystemExit(0)

for item in payload.get("data", []):
    model_id = item.get("id")
    if model_id:
        print("models")
        raise SystemExit(0)

print("empty")
PY
}

config_summary() {
  python3 - "$OPENCLAW_CONFIG_FILE" <<'PY'
import json
import os
import sys

path = os.path.expanduser(sys.argv[1])

summary = {
    "exists": False,
    "path": path,
    "primary": "",
    "base_url": "",
    "configured_models": [],
}

try:
    with open(path, encoding="utf-8") as handle:
        data = json.load(handle)
except OSError:
    print(json.dumps(summary))
    raise SystemExit(0)

summary["exists"] = True
summary["primary"] = (
    data.get("agents", {})
    .get("defaults", {})
    .get("model", {})
    .get("primary", "")
)
provider = data.get("models", {}).get("providers", {}).get("omlx", {})
summary["base_url"] = provider.get("baseUrl", "")
summary["configured_models"] = [
    item.get("id", "") for item in provider.get("models", []) if item.get("id")
]

print(json.dumps(summary))
PY
}

detect_model_from_manifest() {
  python3 - "$PRIMARY_MANIFEST" <<'PY'
import sys

manifest = sys.argv[1]

try:
    with open(manifest, encoding="utf-8") as handle:
        for raw_line in handle:
            line = raw_line.split("#", 1)[0].strip()
            if not line:
                continue
            print(line.rsplit("/", 1)[-1])
            break
        else:
            raise SystemExit(1)
except OSError:
    raise SystemExit(1)
PY
}

configure_openclaw() {
  require_cmd openclaw

  local model_id="${1:-}"
  local model_source="explicit"
  if [ -z "$model_id" ]; then
    model_id="$(detect_model_from_server || true)"
    [ -n "$model_id" ] && model_source="server"
  fi
  if [ -z "$model_id" ]; then
    model_id="$(detect_model_from_manifest || true)"
    [ -n "$model_id" ] && model_source="manifest"
  fi

  if [ -z "$model_id" ]; then
    printf 'Could not detect a model id. Start oMLX or pass a model id explicitly.\n' >&2
    exit 1
  fi

  local batch_json
  batch_json="$(python3 - "$model_id" "$AI_OMLX_HOST" "$AI_OMLX_PORT" "$AI_OPENCLAW_CONTEXT_WINDOW" "$AI_OPENCLAW_MAX_TOKENS" <<'PY'
import json
import sys

model_id = sys.argv[1]
host = sys.argv[2]
port = sys.argv[3]
context_window = int(sys.argv[4])
max_tokens = int(sys.argv[5])

provider = {
    "baseUrl": f"http://{host}:{port}/v1",
    "apiKey": "omlx",
    "api": "openai-responses",
    "models": [
        {
            "id": model_id,
            "name": model_id,
            "reasoning": False,
            "input": ["text"],
            "cost": {
                "input": 0,
                "output": 0,
                "cacheRead": 0,
                "cacheWrite": 0,
            },
            "contextWindow": context_window,
            "maxTokens": max_tokens,
        }
    ],
}

operations = [
    {"path": "models.mode", "value": "merge"},
    {"path": "models.providers.omlx", "value": provider},
    {"path": "agents.defaults.model.primary", "value": f"omlx/{model_id}"},
]

print(json.dumps(operations))
PY
 )"

  openclaw config set --batch-json "$batch_json" --dry-run --json >/dev/null
  openclaw config set --batch-json "$batch_json"
  openclaw config validate >/dev/null
  if [ "$model_source" = "manifest" ]; then
    printf 'Configured OpenClaw from manifest fallback because oMLX did not report any live models.\n'
  fi
  printf 'Configured OpenClaw to use oMLX model omlx/%s\n' "$model_id"
}

show_status() {
  local live_models
  local live_status
  local summary_json
  live_models="$(list_models_from_server || true)"
  live_status="$(server_status)"
  summary_json="$(config_summary)"

  python3 - "$summary_json" "$live_status" "$live_models" <<'PY'
import json
import sys

summary = json.loads(sys.argv[1])
live_status = sys.argv[2]
live_models = [line for line in sys.argv[3].splitlines() if line.strip()]

print(f"Config: {summary['path']}")
print(f"Primary model: {summary['primary'] or 'none'}")
print(f"Endpoint: {summary['base_url'] or 'none'}")

if live_status == "models" and live_models:
    print(f"Live models: {', '.join(live_models)}")
elif live_status == "empty":
    print("Live models: none")
else:
    print("Live models: unreachable")

configured_models = [item for item in summary.get("configured_models", []) if item]
if configured_models:
    print(f"Configured models: {', '.join(configured_models)}")
PY
}

command="${1:-}"
case "$command" in
  configure)
    shift
    configure_openclaw "${1:-}"
    ;;
  status)
    show_status
    ;;
  doctor)
    require_cmd openclaw
    openclaw doctor
    ;;
  dashboard)
    require_cmd openclaw
    openclaw dashboard
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
