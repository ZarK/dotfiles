#!/usr/bin/env bash
set -euo pipefail

AI_HOME="${AI_HOME:-$HOME/.ai}"

usage() {
  cat <<'EOF'
Local AI commands:
  ai                     Show current status
  ai status
  ai start
  ai stop
  ai restart
  ai models
  ai logs
  ai configure [model-id]
  ai download <huggingface-url-or-repo> [target-name]

Advanced:
  ai serve <args...>
  ai model <args...>

Examples:
  ai status
  ai start
  ai models
  ai configure
  ai download https://huggingface.co/Brooooooklyn/Qwen3.6-35B-A3B-UD-Q8_K_XL-mlx
EOF
}

show_status() {
  local model_dir
  local local_entries
  local serve_summary
  local openclaw_summary
  local manifest_entries

  model_dir="$("$AI_HOME/bin/ai-model" path)"
  local_entries="$("$AI_HOME/bin/ai-model" list || true)"
  serve_summary="$("$AI_HOME/bin/ai-serve" status)"
  openclaw_summary="$("$AI_HOME/bin/ai-openclaw" status)"
  manifest_entries="$("$AI_HOME/bin/ai-model" manifest 2>/dev/null || true)"

  python3 - "$model_dir" "$local_entries" "$serve_summary" "$openclaw_summary" "$manifest_entries" <<'PY'
import sys

model_dir, local_entries, serve_summary, openclaw_summary, manifest_entries = sys.argv[1:6]

def lines(value: str) -> list[str]:
    return [line.strip() for line in value.splitlines() if line.strip()]

local_list = lines(local_entries)
serve_lines = lines(serve_summary)
openclaw_lines = lines(openclaw_summary)
manifest_list = [line for line in lines(manifest_entries) if not line.startswith("# ")]

def lookup(prefix: str, items: list[str], default: str = "") -> str:
    for item in items:
        if item.startswith(prefix):
            return item[len(prefix):].strip()
    return default

state = lookup("State:", serve_lines, "unknown")
endpoint = lookup("Endpoint:", serve_lines, "none")
served = lookup("Served models:", serve_lines, "unknown")

primary = lookup("Primary model:", openclaw_lines, "none")
configured_endpoint = lookup("Endpoint:", openclaw_lines, "none")
live = lookup("Live models:", openclaw_lines, served)

if live == "unreachable":
    live = served
if state != "running" and live == "unreachable":
    live = "none"

print(f"Server: {state} ({endpoint})")
print(f"Configured model: {primary}")
print(f"OpenClaw endpoint: {configured_endpoint}")
print(f"Served: {live}")
print(f"Local: {', '.join(local_list) if local_list else 'none'}")
if manifest_list:
    print(f"Manifest: {', '.join(manifest_list)}")
print(f"Model dir: {model_dir}")
if state != "running":
    print("Next: ai start")
elif primary == "none":
    print("Next: ai configure")
PY
}

show_models() {
  local local_entries
  local served_entries
  local manifest_entries

  local_entries="$($AI_HOME/bin/ai-model list || true)"
  served_entries="$($AI_HOME/bin/ai-serve models 2>&1 || true)"
  manifest_entries="$($AI_HOME/bin/ai-model manifest 2>/dev/null || true)"

  python3 - "$local_entries" "$served_entries" "$manifest_entries" <<'PY'
import sys

local_entries, served_entries, manifest_entries = sys.argv[1:4]

def clean(value: str) -> list[str]:
    return [line.strip() for line in value.splitlines() if line.strip()]

local_list = clean(local_entries)
served_list = clean(served_entries)
manifest_list = [line for line in clean(manifest_entries) if not line.startswith("# ")]
next_step = ""

if served_list and served_list[0].startswith("oMLX is not running at "):
    served_list = []
    next_step = "ai start"
elif served_list == ["No models are currently served."]:
    served_list = []

print(f"Served: {', '.join(served_list) if served_list else 'none'}")
print(f"Local: {', '.join(local_list) if local_list else 'none'}")
if manifest_list:
    print(f"Manifest: {', '.join(manifest_list)}")
if next_step:
    print(f"Next: {next_step}")
PY
}

command="${1:-}"
case "$command" in
  "")
    show_status
    ;;
  download)
    shift
    exec "$AI_HOME/bin/ai-model" download "$@"
    ;;
  status)
    show_status
    ;;
  start)
    exec "$AI_HOME/bin/ai-serve" start
    ;;
  stop)
    exec "$AI_HOME/bin/ai-serve" stop
    ;;
  restart)
    exec "$AI_HOME/bin/ai-serve" restart
    ;;
  models)
    show_models
    ;;
  logs)
    exec "$AI_HOME/bin/ai-serve" logs
    ;;
  configure)
    shift
    exec "$AI_HOME/bin/ai-openclaw" configure "$@"
    ;;
  model)
    shift
    exec "$AI_HOME/bin/ai-model" "$@"
    ;;
  serve)
    shift
    exec "$AI_HOME/bin/ai-serve" "$@"
    ;;
  openclaw)
    shift
    exec "$AI_HOME/bin/ai-openclaw" "$@"
    ;;
  help|--help|-h)
    usage
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
